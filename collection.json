{
  "info": {
    "name": "subIV-carSales-integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List available cars",
      "request": {
        "method": "GET",
        "url": "http://localhost:8081/api/sales/cars/available"
      }
    },
    {
      "name": "Purchase car",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:8081/api/sales/purchase",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"carId\":\"{{carId}}\",\n  \"buyerCpf\":\"12345678901\",\n  \"saleDate\":\"2026-06-12T10:00:00Z\"\n}"
        }
      }
    },
    {
      "name": "Confirm payment webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "http://localhost:8081/api/webhooks/payments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentCode\":\"{{paymentCode}}\",\n  \"status\":1\n}"
        }
      }
    },
    {
      "name": "List sold cars",
      "request": {
        "method": "GET",
        "url": "http://localhost:8081/api/sales/cars/sold"
      }
    }
  ]
}